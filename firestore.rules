rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: employees
    // Collection: invoices
    // Collection: projects
    // Collection: farms
    // Collection: files
    // Collection: family
    // Collection: home_expenses
    // Collection: events
    // Collection: home_files
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "agreenmarket1@gmail.com");
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /employees/{id} {
      allow read, write: if isAuthenticated();
    }

    match /invoices/{id} {
      allow read, write: if isAuthenticated();
    }

    match /projects/{id} {
      allow read, write: if isAuthenticated();
    }

    match /farms/{id} {
      allow read, write: if isAuthenticated();
    }

    match /files/{id} {
      allow read, write: if isAuthenticated();
    }

    match /family/{id} {
      allow read, write: if isAuthenticated();
    }

    match /home_expenses/{id} {
      allow read, write: if isAuthenticated();
    }

    match /events/{id} {
      allow read, write: if isAuthenticated();
    }

    match /home_files/{id} {
      allow read, write: if isAuthenticated();
    }

    match /settings_tax/{id} {
      allow read, write: if isAuthenticated();
    }

    match /attendance/{id} {
      allow read, write: if isAuthenticated();
    }

    match /leaves/{id} {
      allow read, write: if isAuthenticated();
    }

    match /loans/{id} {
      allow read, write: if isAuthenticated();
    }

    match /penalties/{id} {
      allow read, write: if isAuthenticated();
    }

    match /ai_history/{id} {
      allow read, write: if isAuthenticated();
    }
  }
}
